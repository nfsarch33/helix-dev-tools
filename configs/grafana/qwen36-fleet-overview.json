          "type": "prometheus",
          "uid": "prom"
        },
        "definition": "label_values(qwen_fleet_lane_samples_total, cell_id)",
        "hide": 0,
        "includeAll": true,
        "label": "Lane",
        "multi": true,
        "name": "cell_id",
        "options": [],
        "query": {
          "qryType": 1,
          "query": "label_values(qwen_fleet_lane_samples_total, cell_id)"
        },
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-2h",
    "to": "now"
  },
