{
  "annotations": {
    "list": []
  },
  "description": "Tier-A subagent offload telemetry from cursor-tools tier-a metric record. Source: Prometheus scrape against http://127.0.0.1:9787/metrics (zd-claude-proxy, MacBook only). Series: zd_claude_proxy_tier_a_offload_total (counter), zd_claude_proxy_tier_a_offload_latency_seconds (histogram).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Decision mix",
      "type": "row"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 10,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (decision) (rate(zd_claude_proxy_tier_a_offload_total[5m]))",
          "legendFormat": "{{decision}}",
          "refId": "A"
        }
      ],
      "title": "Tier-A decisions / second",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 11,
      "targets": [
        {
          "expr": "100 * sum(rate(zd_claude_proxy_tier_a_offload_total{decision=\"offloaded\"}[15m])) / sum(rate(zd_claude_proxy_tier_a_offload_total[15m]))",
          "legendFormat": "offload rate",
          "refId": "A"
        },
        {
          "expr": "100 * sum(rate(zd_claude_proxy_tier_a_offload_total{decision=\"declined\"}[15m])) / sum(rate(zd_claude_proxy_tier_a_offload_total[15m]))",
          "legendFormat": "decline rate",
          "refId": "B"
        }
      ],
      "title": "Offload vs decline rate (15m)",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 2,
      "title": "Latency",
      "type": "row"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "id": 20,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, route) (rate(zd_claude_proxy_tier_a_offload_latency_seconds_bucket[5m])))",
          "legendFormat": "p50 {{route}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(zd_claude_proxy_tier_a_offload_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{route}}",
          "refId": "B"
        }
      ],
      "title": "Offload latency p50/p95 by route",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "id": 21,
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, route) (rate(zd_claude_proxy_tier_a_offload_latency_seconds_bucket[5m])))",
          "legendFormat": "p99 {{route}}",
          "refId": "A"
        }
      ],
      "title": "Offload latency p99 by route",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "id": 3,
      "title": "Volume by route",
      "type": "row"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 19
      },
      "id": 30,
      "targets": [
        {
          "expr": "sum by (route, decision) (increase(zd_claude_proxy_tier_a_offload_total[1h]))",
          "legendFormat": "{{route}} ({{decision}})",
          "refId": "A"
        }
      ],
      "title": "Decisions per route (1h increase)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": [
    "cursor-tools",
    "zd-claude-proxy",
    "tier-a"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Tier-A Offload Overview",
  "uid": "cursor-tier-a-offload",
  "version": 1
}

