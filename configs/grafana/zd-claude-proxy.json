{
  "annotations": {
    "list": []
  },
  "description": "Per-route, per-model latency, throughput and token totals for zd-claude-proxy. Source: Prometheus scrape against http://127.0.0.1:9787/metrics on the MacBook only.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Throughput",
      "type": "row"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 10,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (route) (rate(zd_claude_proxy_requests_total[1m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Requests / second by route",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 11,
      "targets": [
        {
          "expr": "sum by (route, upstream_status) (rate(zd_claude_proxy_requests_total{upstream_status!~\"2..\"}[1m]))",
          "legendFormat": "{{route}} ({{upstream_status}})",
          "refId": "A"
        }
      ],
      "title": "Errors / second (status \u003e= 400)",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 2,
      "title": "Latency",
      "type": "row"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "id": 20,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (route, le) (rate(zd_claude_proxy_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{route}}",
          "refId": "A"
        }
      ],
      "title": "p95 upstream latency by route",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "id": 21,
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (model, le) (rate(zd_claude_proxy_latency_seconds_bucket[5m])))",
          "legendFormat": "p50 {{model}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(zd_claude_proxy_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{model}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (model, le) (rate(zd_claude_proxy_latency_seconds_bucket[5m])))",
          "legendFormat": "p99 {{model}}",
          "refId": "C"
        }
      ],
      "title": "p50 / p95 / p99 by model (top 5)",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "id": 3,
      "title": "Tokens",
      "type": "row"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "id": 30,
      "targets": [
        {
          "expr": "sum by (direction) (rate(zd_claude_proxy_tokens_total[1m]))",
          "legendFormat": "{{direction}} tokens/s",
          "refId": "A"
        }
      ],
      "title": "Token throughput by direction",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "id": 31,
      "options": {
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum by (model) (increase(zd_claude_proxy_tokens_total[24h]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Total tokens (24h) by model",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "id": 4,
      "title": "Concurrency",
      "type": "row"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "id": 40,
      "targets": [
        {
          "expr": "zd_claude_proxy_inflight",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "In-flight upstream calls",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": [
    "zd-claude-proxy",
    "macbook",
    "ai-gateway"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "ZD Claude Proxy",
  "uid": "zd-claude-proxy",
  "version": 1,
  "weekStart": ""
}

